{
  "expo": {
    "name": "Servigic Pro",
    "slug": "servigic-pro",
    "scheme": "servigic-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0F",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servigic.pro",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Servigic Pro shares your location with the customer while you're on the way to a job.",
        "UIBackgroundModes": ["location", "remote-notification"]
      }
    },
    "android": {
      "package": "com.servigic.pro",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_GOOGLE_MAPS_ANDROID_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Servigic Pro shares your location with the customer while you're on the way to a job."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Servigic Pro needs access to your photos to upload verification documents."
        }
      ]
    ]
  }
}
