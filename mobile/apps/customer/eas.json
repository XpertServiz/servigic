{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.servigic.com",
        "EXPO_PUBLIC_JAZZCASH_NUMBER": "0300-0000000",
        "EXPO_PUBLIC_EASYPAISA_NUMBER": "0300-0000000",
        "EXPO_PUBLIC_BANK_ACCOUNT_TITLE": "Servigic (Pvt) Ltd",
        "EXPO_PUBLIC_BANK_ACCOUNT_NUMBER": "0000-0000000000-00",
        "EXPO_PUBLIC_BANK_NAME": "Meezan Bank"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.servigic.com",
        "EXPO_PUBLIC_JAZZCASH_NUMBER": "0300-0000000",
        "EXPO_PUBLIC_EASYPAISA_NUMBER": "0300-0000000",
        "EXPO_PUBLIC_BANK_ACCOUNT_TITLE": "Servigic (Pvt) Ltd",
        "EXPO_PUBLIC_BANK_ACCOUNT_NUMBER": "0000-0000000000-00",
        "EXPO_PUBLIC_BANK_NAME": "Meezan Bank"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
