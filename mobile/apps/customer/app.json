{
  "expo": {
    "name": "Servigic",
    "slug": "servigic-customer",
    "scheme": "servigic-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0F",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servigic.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Servigic uses your location to set the job's location and find nearby pros."
      }
    },
    "android": {
      "package": "com.servigic.customer",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDUNVlPXrrOVsSpwQ59KQQ8t8QnqLalrAg"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Servigic uses your location to set the job's location and find nearby pros."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Servigic needs access to your photos to attach job photos and payment proof."
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": false
        }
      ]
    ],
    "owner": "xpertserviz-786",
    "extra": {
      "eas": {
        "projectId": "33d8f4e9-8c36-4a3d-a933-22ef65847614"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/33d8f4e9-8c36-4a3d-a933-22ef65847614"
    }
  }
}
